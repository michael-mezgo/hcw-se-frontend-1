{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["cypress"],
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
